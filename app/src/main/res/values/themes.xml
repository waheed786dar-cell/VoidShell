<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.VoidShell" parent="android:Theme.Material.NoTitleBar.Fullscreen">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:statusBarColor">#FF050A0E</item>
        <item name="android:navigationBarColor">#FF050A0E</item>
    </style>
    <style name="Theme.VoidShell.SplashScreen" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#FF050A0E</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon</item>
        <item name="postSplashScreenTheme">@style/Theme.VoidShell</item>
    </style>
</resources>
